  },
  "agent_config": {
    "default_agent": "simple",
    "agent_verbose": true,
    "faiss_search_k": 5,
    "max_search_results": 5
  },
  "ui_config": {
    "api_host": "0.0.0.0",
    "api_port": 8000,
    "ui_host": "0.0.0.0",
    "ui_port": 7860,
    "ui_theme": "soft",
    "chat_height": 400,
    "max_chat_history": 50,
    "share_gradio": false
  },
  "logging_config": {
    "log_level": "INFO",
    "log_file": "genai.log",
    "debug_mode": false
  }
}