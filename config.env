# Configuration for Multi-Agent RAG System
# NOTE: This file serves as a template/documentation.
# 
# HF_TOKEN Priority Order:
# 1. UI Settings (highest - can override everything)
# 2. .env file (fallback for security)  
# 3. Default value (lowest - placeholder)

# ===============================
# CORE AI CONFIGURATION (USED)
# ===============================

# HuggingFace Configuration
# HF_TOKEN can be provided via UI or .env when needed

# ===============================
# PROJECT SETTINGS (CURRENT)
# ===============================

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
UI_HOST=0.0.0.0  
UI_PORT=7860

# Vector Store Configuration
VECTOR_DIMENSION=768
VECTOR_INDEX_PATH=E:/PythonLLMProject/faiss_indexes


# File Processing
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# Search Settings
FAISS_SEARCH_K=5
MAX_SEARCH_RESULTS=5

# Agent Settings
DEFAULT_AGENT=simple
AGENT_VERBOSE=true
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.1

# UI Settings
# UI_THEME is handled by frontend CSS; keep CHAT_HEIGHT if needed
CHAT_HEIGHT=400
MAX_CHAT_HISTORY=50

# Cache Settings
CACHE_MAXSIZE=1

# Logging is configured in services/logger.py

# Development
DEBUG_MODE=false
SHARE_GRADIO=false
