# Configuration for Multi-Agent RAG System
# NOTE: This file serves as a template/documentation.
# 
# HF_TOKEN Priority Order:
# 1. UI Settings (highest - can override everything)
# 2. .env file (fallback for security)  
# 3. Default value (lowest - placeholder)

# ===============================
# CORE AI CONFIGURATION (USED)
# ===============================

# HuggingFace Configuration
# HF_TOKEN=your_huggingface_token_here  # Default value, override in .env or UI
HF_MODEL=Qwen/Qwen2.5-72B-Instruct

# Ollama Configuration  
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b

# CrewAI Configuration
CREWAI_TRACING_ENABLED=false

# ===============================
# PROJECT SETTINGS (CURRENT)
# ===============================

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
UI_HOST=0.0.0.0  
UI_PORT=7860

# Vector Store Configuration
VECTOR_DIMENSION=768
VECTOR_INDEX_PATH=faiss_indexes
EMBEDDING_MODEL=nomic-embed-text:v1.5

# File Processing
MAX_FILE_SIZE=50MB
ALLOWED_FILE_TYPES=.pdf,.txt,.docx,.xlsx
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# Search Settings
FAISS_SEARCH_K=5
MAX_SEARCH_RESULTS=5

# Agent Settings
DEFAULT_AGENT=simple
AGENT_VERBOSE=true
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.1

# UI Settings
UI_THEME=soft
CHAT_HEIGHT=400
MAX_CHAT_HISTORY=50

# Logging
LOG_LEVEL=INFO
LOG_FILE=genai.log

# Development
DEBUG_MODE=false
SHARE_GRADIO=false
HF_TOKEN='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'
